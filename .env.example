# Copiar este archivo como .env y ajustar los valores
PORT=3000
DB_HOST=cromos-db.xxxxxxxxxx.us-east-2.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=
DB_NAME=cromos

# Bucket donde se guardan las imagenes de los cromos.
# Las credenciales de AWS no van aqui: el EC2 usa un rol IAM.
AWS_REGION=us-east-2
S3_BUCKET=cromos-imagenes-vparedes-2026
